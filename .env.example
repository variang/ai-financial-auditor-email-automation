NODE_ENV=development
APP_LOG_LEVEL=info

# Google owner account for spreadsheet creation.
GOOGLE_OWNER_EMAIL=

# Existing spreadsheet used as the audit destination.
GOOGLE_SPREADSHEET_ID=

# Service account key file used by Google Sheets adapter.
GOOGLE_CREDENTIALS_PATH=

# Gmail Pub/Sub watch configuration.
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-watch

PLACEHOLDER_RECIPIENT_EMAIL=unknown@placeholder.invalid
PLACEHOLDER_CARD_NICKNAME=Unknown-Card

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Processing rules.
AUTO_REPLY_ENABLED=true
REPLY_SUMMARY_MAX_LINES=4
TAB_DATE_FORMAT=YYYY-MM

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=email-financial-auditor

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9464

# Webhook server (receives Gmail Pub/Sub push notifications)
WEBHOOK_PORT=8080
# Optional token for Pub/Sub push verification. Add ?token=<value> to your subscription endpoint URL.
PUBSUB_VERIFICATION_TOKEN=

LLM_MODEL=placeholder-model

OPENAI_API_KEY=
